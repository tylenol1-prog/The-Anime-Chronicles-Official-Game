#!/usr/bin/env python3
import random
import time

class GameContext:
    def __init__(self):
        self.game_title = "Anime Chronicles: World Salvation"
        self.version = "2.2.0 PIXEL FIX"
        self.game_title = "Move until You find an enemy!"
        self.build_number = 9200
        self.is_running = True
        self.system_ready = False
        self.current_act = 1
        self.world_stability_index = 100.0
        self.cataclysm_countdown_hours = 24

    def display_boot_logo(self):
        print("=" * 72)
        print("      ✨ ANIME CHRONICLES: WORLD SALVATION ✨!")
        
        print("=" * 72)
        print(f" System Version: {self.version} | Build: {self.build_number}")
        print(" Loading pixel hero... please wait.")
        print("-" * 72)


class PlayerDataStructure:
    def __init__(self):
        self.player_name = "DefaultHero"
        self.chosen_class = "Rogue"
        self.current_level = 1
        self.experience_points = 0
        self.next_level_experience = 100
        self.health_points = 200
        self.maximum_health_points = 200
        self.mana_points = 100
        self.maximum_mana_points = 100
        self.base_attack_power = 30
        self.base_defense_rating = 20
        self.crit_chance = 0.1
        self.equipped_weapon = "Legendary Spoon"
        self.equipped_armor = "Plot Armor"
        self.inventory_slots = ["Potion of Vibes", "Snack Scroll"]
        self.x = 5
        self.y = 5

    def update_stats(self):
        self.maximum_health_points = 200 + (self.current_level * 25)
        self.maximum_mana_points = 100 + (self.current_level * 12)
        self.base_attack_power = 30 + (self.current_level * 5)
        self.base_defense_rating = 20 + (self.current_level * 4)


class Monster:
    def __init__(self, level=1):
        self.name = random.choice(["Slime", "Goblin", "Bat", "Shadow Wolf"])
        self.level = level
        self.maximum_health_points = 50 + (level * 20)
        self.health_points = self.maximum_health_points
        self.attack_power = 10 + (level * 6)
        self.experience_reward = 25 + (level * 15)

    def is_alive(self):
        return self.health_points > 0


class PixelWorld:
    def __init__(self, width=12, height=8):
        self.width = width
        self.height = height
        self.player_x = width // 2
        self.player_y = height // 2

    def draw(self):
        print("\n🟦 Pixel World")
        for y in range(self.height):
            row = ""
            for x in range(self.width):
                row += "@" if (x == self.player_x and y == self.player_y) else "."
            print(row)
        print("Legend: @ = your pixel hero")

    def move(self, direction):
        if direction == "w":
            self.player_y = max(0, self.player_y - 1)
        elif direction == "s":
            self.player_y = min(self.height - 1, self.player_y + 1)
        elif direction == "a":
            self.player_x = max(0, self.player_x - 1)
        elif direction == "d":
            self.player_x = min(self.width - 1, self.player_x + 1)


def initialize_game():
    game_context = GameContext()
    game_context.display_boot_logo()

    player = PlayerDataStructure()
    name = input("Enter your hero name: ").strip()
    if name:
        player.player_name = name

    print("\n[CLASS SELECTION]")
    print("1) Warrior")
    print("2) Mage")
    print("3) Rogue")
    class_choice = input("Choose class (1-3): ").strip()

    if class_choice == "1":
        player.chosen_class = "Warrior"
        player.base_attack_power = 45
        player.base_defense_rating = 35
    elif class_choice == "2":
        player.chosen_class = "Mage"
        player.mana_points = 200
        player.maximum_mana_points = 200
        player.base_attack_power = 35
    else:
        player.chosen_class = "Rogue"
        player.crit_chance = 0.15

    player.update_stats()
    if player.chosen_class == "Warrior":
        player.base_attack_power += 10
        player.base_defense_rating += 8
    elif player.chosen_class == "Mage":
        player.maximum_mana_points += 100
        player.mana_points = player.maximum_mana_points
        player.base_attack_power += 5
    elif player.chosen_class == "Rogue":
        player.crit_chance += 0.05

    pixel_world = PixelWorld()
    game_context.system_ready = True
    return game_context, player, pixel_world


def show_hud(player, game_context):
    print("\n" + "=" * 60)
    print(f" HERO: {player.player_name} | CLASS: {player.chosen_class}")
    print(f" LVL {player.current_level} | HP {player.health_points}/{player.maximum_health_points} | MP {player.mana_points}/{player.maximum_mana_points}")
    print(f" POS: ({player.x}, {player.y}) | WORLD: {game_context.world_stability_index}%")
    print("=" * 60)
    print("1) Move pixel hero")
    print("2) Rest")
    print("3) Exit")
    return input("Choose: ").strip()


def battle(player, monster, game_context):
    print(f"\n⚔️ A wild {monster.name} appeared! Lv.{monster.level}")
    while player.health_points > 0 and monster.is_alive():
        print(f"\n{player.player_name} HP: {player.health_points}/{player.maximum_health_points}")
        print(f"{monster.name} HP: {monster.health_points}/{monster.maximum_health_points}")
        print("1) Attack")
        print("2) Defend")
        print("3) Run")
        action = input("Choose: ").strip()

        if action == "1":
            crit = random.random() < player.crit_chance
            damage = player.base_attack_power + random.randint(0, 10)
            if crit:
                damage *= 2
                print("✨ Critical hit!")
            monster.health_points = max(0, monster.health_points - damage)
            print(f"You hit the {monster.name} for {damage} damage.")

        elif action == "2":
            print("🛡️ You brace for impact.")
            reduced = max(1, monster.attack_power - player.base_defense_rating // 2)
            player.health_points = max(0, player.health_points - reduced)
            print(f"The {monster.name} hits you for {reduced} damage.")

        elif action == "3":
            if random.random() < 0.5:
                print("🏃 You escaped successfully!")
                return
            else:
                print("❌ Escape failed!")

        else:
            print("⚠️ Invalid action.")
            continue

        if monster.is_alive():
            incoming = max(1, monster.attack_power - player.base_defense_rating // 3)
            player.health_points = max(0, player.health_points - incoming)
            print(f"The {monster.name} attacks for {incoming} damage.")

    if player.health_points <= 0:
        print("\n💀 You were defeated...")
        game_context.is_running = False
        return

    gained_xp = monster.experience_reward
    player.experience_points += gained_xp
    print(f"\n🏆 You defeated the {monster.name} and gained {gained_xp} XP!")

    while player.experience_points >= player.next_level_experience:
        player.experience_points -= player.next_level_experience
        player.current_level += 1
        player.next_level_experience = 100 + (player.current_level * 50)
        player.update_stats()
        player.health_points = player.maximum_health_points
        player.mana_points = player.maximum_mana_points
        print(f"🌟 Level up! You are now level {player.current_level}.")


def maybe_trigger_encounter(player, game_context):
    if random.random() < 0.45:
        monster_level = max(1, player.current_level + random.randint(-1, 1))
        monster = Monster(level=monster_level)
        battle(player, monster, game_context)
    else:
        print("The area is quiet... no monsters here.")


def main_game_loop(game_context, player, pixel_world):
    while game_context.is_running:
        pixel_world.draw()
        choice = show_hud(player, game_context)

        if choice == "1":
            print("\nMove with W/A/S/D, Q to stop.")
            while True:
                pixel_world.draw()
                move = input("Move: ").strip().lower()
                if move == "q":
                    break
                if move in ("w", "a", "s", "d"):
                    pixel_world.move(move)
                    player.x = pixel_world.player_x
                    player.y = pixel_world.player_y
                    print(f"✨ {player.player_name} moved to ({player.x}, {player.y})")
                    maybe_trigger_encounter(player, game_context)
                    if not game_context.is_running:
                        break
                else:
                    print("⚠️ Use W/A/S/D or Q.")

        elif choice == "2":
            player.health_points = player.maximum_health_points
            player.mana_points = player.maximum_mana_points
            print("😴 You rested. HP and MP fully restored!")
        elif choice == "3":
            print("👋 Goodbye, hero!")
            game_context.is_running = False
        else:
            print("⚠️ Invalid choice.")


def main():
    try:
        game_context, player, pixel_world = initialize_game()
        main_game_loop(game_context, player, pixel_world)
    except KeyboardInterrupt:
        print("\n\n[SYSTEM] Interrupted. Shutting down safely...")
    except Exception as e:
        print(f"\n[CRITICAL ERROR] {e}")


if __name__ == "__main__":
    main()
